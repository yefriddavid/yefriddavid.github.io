# ─── CashFlow Firebase Project ────────────────────────────────────────────────
VITE_FIREBASE_API_KEY=AIzaSy-your-cashflow-api-key-here
VITE_FIREBASE_AUTH_DOMAIN=your-cashflow-project.firebaseapp.com
VITE_FIREBASE_PROJECT_ID=your-cashflow-project
VITE_FIREBASE_STORAGE_BUCKET=your-cashflow-project.firebasestorage.app
VITE_FIREBASE_MESSAGING_SENDER_ID=000000000000
VITE_FIREBASE_APP_ID=1:000000000000:web:your-cashflow-app-id
VITE_FIREBASE_VAPID_KEY=your-web-push-vapid-public-key-from-firebase-console
VITE_RECAPTCHA_SITE_KEY=your-recaptcha-v2-site-key
VITE_FIREBASE_DATABASE_URL=https://your-cashflow-project-default-rtdb.firebaseio.com

# ─── Taxi Firebase Project ────────────────────────────────────────────────────
VITE_TAXI_API_KEY=AIzaSy-your-taxi-api-key-here
VITE_TAXI_AUTH_DOMAIN=your-taxi-project.firebaseapp.com
VITE_TAXI_PROJECT_ID=your-taxi-project
VITE_TAXI_STORAGE_BUCKET=your-taxi-project.firebasestorage.app
VITE_TAXI_MESSAGING_SENDER_ID=111111111111
VITE_TAXI_APP_ID=1:111111111111:web:your-taxi-app-id
VITE_TAXI_DATABASE_URL=https://your-taxi-project-default-rtdb.firebaseio.com

# ─── Domotica Firebase Project ────────────────────────────────────────────────
VITE_DOMOTICA_API_KEY=AIzaSy-your-domotica-api-key-here
VITE_DOMOTICA_AUTH_DOMAIN=your-domotica-project.firebaseapp.com
VITE_DOMOTICA_PROJECT_ID=your-domotica-project
VITE_DOMOTICA_STORAGE_BUCKET=your-domotica-project.firebasestorage.app
VITE_DOMOTICA_MESSAGING_SENDER_ID=222222222222
VITE_DOMOTICA_APP_ID=1:222222222222:web:your-domotica-app-id
VITE_DOMOTICA_DATABASE_URL=https://your-domotica-project-default-rtdb.firebaseio.com

# ─── Third-party tokens ────────────────────────────────────────────────────────
VITE_IPINFO_TOKEN=your-ipinfo-token-here

# Optional — enables the AI audit chat at the bottom of Taxis > Settlements.
# Leave unset to keep that chat hidden (build/deploy without this var = no chat).
VITE_ANTHROPIC_API_KEY=sk-ant-your-key-here

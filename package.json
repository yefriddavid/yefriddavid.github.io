{
  "name": "@dave/MyAdmin",
  "version": "5.2.0",
  "description": "CoreUI Free React Admin Template",
  "homepage": "https://yefriddavid.github.io/yefriddavid.github.io",
  "bugs": {
    "url": "https://github.com/coreui/coreui-free-react-admin-template/issues"
  },
  "repository": {
    "type": "git",
    "url": "git@github.com:coreui/coreui-free-react-admin-template.git"
  },
  "license": "MIT",
  "author": "The CoreUI Team (https://github.com/orgs/coreui/people)",
  "scripts": {
    "predeploy": "npm run build",
    "deploy": "gh-pages -d build",
    "local:build": "cross-env NODE_OPTIONS=--max-old-space-size=8192 vite build",
    "build": "vite build",
    "lint": "eslint \"src/**/*.{js,jsx}\"",
    "lint:fix": "eslint \"src/**/*.{js,jsx}\" --fix",
    "serve": "vite preview",
    "start": "vite",
    "start:prod": "vite --mode production",
    "copy-to-test": "node scripts/copy-prod-to-test.mjs",
    "test": "vitest run",
    "test:app": "cross-env NODE_OPTIONS=--max-old-space-size=8192 vitest run --config vitest.app.config.mjs --no-file-parallelism",
    "test:watch": "vitest",
    "serve:test": "vite preview --port 3005",
    "cy:open": "cypress open",
    "cy:comp": "cypress run --component",
    "cy:comp:open": "cypress open --component",
    "cy:run-legacy": "start-server-and-test serve:test 3005 \"cypress run --config baseUrl=http://localhost:3005\"",
    "cy:run": "cypress run --config baseUrl=http://localhost:3000",
    "cy:run:raw": "cypress run --config baseUrl=http://localhost:3005",
    "cy:parallel": "cypress-parallel -s cy:run:raw -t 2 -d cypress/e2e",
    "cy:run:parallel": "start-server-and-test serve:test 3005 \"npm run cy:parallel\""
  },
  "dependencies": {
    "@coreui/chartjs": "^4.0.0",
    "@coreui/coreui": "^5.2.0",
    "@coreui/icons": "^3.0.1",
    "@coreui/icons-react": "^2.3.0",
    "@coreui/react": "^5.4.1",
    "@coreui/react-chartjs": "^3.0.0",
    "@coreui/utils": "^2.0.2",
    "@devexpress/analytics-core": "^24.2.3",
    "@material-ui/core": "^4.12.4",
    "@material-ui/lab": "^4.0.0-alpha.61",
    "@mescius/activereportsjs-react": "^5.1.5",
    "@popperjs/core": "^2.11.8",
    "@reduxjs/toolkit": "^2.5.0",
    "axios": "^1.7.9",
    "chart.js": "^4.4.6",
    "classnames": "^2.5.1",
    "cookies-next": "^5.1.0",
    "core-js": "^3.39.0",
    "devexpress-reporting": "^24.2.3",
    "devexpress-reporting-react": "^24.2.3",
    "devextreme": "^24.2.3",
    "devextreme-react": "^24.2.3",
    "firebase": "^11.1.0",
    "html2canvas": "^1.4.1",
    "i18next": "^24.2.0",
    "i18next-http-backend": "^3.0.1",
    "json-rules-engine": "^7.3.1",
    "jspdf": "^4.2.1",
    "jspdf-autotable": "^5.0.7",
    "moment": "^2.30.1",
    "pdfjs-dist": "^3.11.174",
    "prop-types": "^15.8.1",
    "react": "^18.3.1",
    "react-datepicker": "^7.6.0",
    "react-dom": "^18.3.1",
    "react-hook-form": "^7.54.2",
    "react-i18next": "^15.4.0",
    "react-redux": "^9.2.0",
    "react-reportbro-designer": "^1.0.4",
    "react-router-dom": "^6.28.0",
    "redux": "5.0.1",
    "redux-act": "^1.8.0",
    "redux-saga": "^1.3.0",
    "simplebar-react": "^3.2.6",
    "tesseract.js": "^7.0.0",
    "xlsx": "^0.18.5"
  },
  "devDependencies": {
    "@testing-library/dom": "^10.4.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@vitejs/plugin-legacy": "^5.4.3",
    "@vitejs/plugin-react": "^4.3.3",
    "autoprefixer": "^10.4.20",
    "cross-env": "^10.1.0",
    "cypress": "^15.13.1",
    "cypress-multi-reporters": "^2.0.5",
    "cypress-parallel": "^0.15.0",
    "eslint": "^8.57.0",
    "eslint-config-prettier": "^9.1.0",
    "eslint-plugin-prettier": "^5.2.1",
    "eslint-plugin-react": "^7.37.2",
    "eslint-plugin-react-hooks": "^4.6.2",
    "firebase-admin": "^13.7.0",
    "jsdom": "^29.0.1",
    "mocha-junit-reporter": "^2.2.1",
    "postcss": "^8.4.49",
    "prettier": "3.3.3",
    "sass": "^1.81.0",
    "start-server-and-test": "^3.0.2",
    "terser": "^5.46.1",
    "vite": "^5.4.11",
    "vite-plugin-pwa": "^1.2.0",
    "vitest": "^4.1.1"
  }
}
